{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@odirico/core": [
        "./src/vendor/odirico/core"
      ],
      "@odirico/core/*": [
        "./src/vendor/odirico/core/*"
      ],
      "@odirico/auth": [
        "./src/vendor/odirico/auth"
      ],
      "@odirico/auth/*": [
        "./src/vendor/odirico/auth/*"
      ],
      "@odirico/api": [
        "./src/vendor/odirico/api"
      ],
      "@odirico/api/*": [
        "./src/vendor/odirico/api/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
