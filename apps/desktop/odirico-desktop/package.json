{
  "name": "@odirico/odirico-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "node ./scripts/run-build.mjs",
    "dev": "node ./node_modules/vite/bin/vite.js --host 0.0.0.0 --port 1420",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host 0.0.0.0 --port 1420",
    "tauri": "node ./node_modules/@tauri-apps/cli/tauri.js",
    "tauri:build": "node ./node_modules/@tauri-apps/cli/tauri.js build",
    "tauri:dev": "node ./node_modules/@tauri-apps/cli/tauri.js dev",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "latest"
  },
  "devDependencies": {
    "@tauri-apps/cli": "latest",
    "typescript": "^5.9.0",
    "vite": "latest"
  }
}
